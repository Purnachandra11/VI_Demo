{
  "name": "telecom-wdio-automation",
  "version": "2.0.0",
  "description": "WebdriverIO + TypeScript + Appium mobile automation for telecom UAT",
  "private": true,
  "scripts": {
    "setup": "npm install && cd dashboard && npm install",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "wdio": "wdio run ./wdio.conf.ts",
    "wdio:local": "wdio run ./config/wdio.local.conf.ts",
    "wdio:dual": "wdio run ./config/wdio.dual.conf.ts",
    "test:smoke": "cross-env WDIO_SPECS=./test/specs/smoke.spec.ts npm run wdio",
    "test:calling": "cross-env WDIO_SPECS=./test/specs/calling.spec.ts npm run wdio",
    "test:sms": "cross-env WDIO_SPECS=./test/specs/sms.spec.ts npm run wdio",
    "test:data": "cross-env WDIO_SPECS=./test/specs/data.spec.ts npm run wdio",
    "test:calling-sms": "cross-env WDIO_SPECS=./test/specs/calling.spec.ts,./test/specs/sms.spec.ts npm run wdio",
    "test:all": "cross-env WDIO_SPECS=./test/specs/calling.spec.ts,./test/specs/sms.spec.ts,./test/specs/data.spec.ts npm run wdio",
    "test:sim-latch": "cross-env WDIO_SPECS=./test/specs/sim-latch.spec.ts npm run wdio",
    "test:sim-toolkit": "cross-env WDIO_SPECS=./test/specs/sim-toolkit.spec.ts npm run wdio",
    "test:ussd": "ts-node test/specs/main.ts",
    "test:calling-data": "cross-env WDIO_SPECS=./test/specs/calling.spec.ts,./test/specs/data.spec.ts npm run wdio",
    "test:sms-data": "cross-env WDIO_SPECS=./test/specs/sms.spec.ts,./test/specs/data.spec.ts npm run wdio",
    "report:generate": "node -r ts-node/register/transpile-only -e \"require('./test/reporting').flushReports().then(m=>console.log(JSON.stringify(m,null,2)))\"",
    "report:summary": "node -r ts-node/register/transpile-only -e \"const {TestSummarizer}=require('./test/ai/testSummarizer'); new TestSummarizer().writeSummary('reports/execution-summary.json');\"",
    "report:allure": "allure generate allure-results -o allure-report --clean",
    "report:allure:open": "npm run report:allure && allure open allure-report",
    "test:siebel": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/siebel_full_workflow.spec.ts",
    "test:siebel:login": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/siebel_login.spec.ts",
    "test:siebel:subscription": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/siebel_subscription_validation.spec.ts",
    "test:siebel:invoice": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/siebel_invoice_validation.spec.ts",
    "test:siebel:debug": "npx wdio run test/config/wdio.siebel.conf.ts --debug",
    "serenity": "failsafe serenity:clean wdio serenity:report",
    "serenity:clean": "rimraf target",
    "serenity:report": "serenity-bdd run",
    "test:invoice": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/siebel_invoice_validation.spec.ts",
    "test:debug": "npx wdio run test/config/wdio.siebel.conf.ts --spec test/specs/debug-test.spec.ts",
    "test:single": "npx wdio run test/config/wdio.siebel.conf.ts --spec",
    "setup:dirs": "mkdir -p screenshots/invoice reports/invoice test_data logs",
    "clean:reports": "rm -rf reports/invoice/* screenshots/invoice/*"
  },
  "dependencies": {
    "chai": "^4.5.0",
    "exceljs": "^3.4.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "webdriverio": "^9.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@serenity-js/assertions": "^3.43.2",
    "@serenity-js/console-reporter": "^3.43.2",
    "@serenity-js/core": "^3.43.2",
    "@serenity-js/mocha": "^3.43.2",
    "@serenity-js/rest": "^3.43.2",
    "@serenity-js/serenity-bdd": "^3.43.2",
    "@serenity-js/web": "^3.43.2",
    "@serenity-js/webdriverio": "^3.43.2",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@wdio/allure-reporter": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/junit-reporter": "^9.21.0",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "chai": "^4.3.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "expect-webdriverio": "^5.6.7",
    "mocha": "^11.7.6",
    "npm-failsafe": "^1.4.0",
    "pdf-parse": "^2.4.5",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "wdio-json-html-reporter": "^1.5.14",
    "webdriverio": "^9.27.2"
  }
}
