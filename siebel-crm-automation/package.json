{
  "name": "siebel-crm-automation",
  "version": "1.0.0",
  "description": "WebdriverIO + TypeScript automation for Siebel CRM invoice validation",
  "private": true,
  "scripts": {
    "test:siebel": "wdio run ./config/wdio.siebel.conf.ts",
    "test:login": "wdio run ./config/wdio.siebel.conf.ts --spec ./specs/siebel_login_only.spec.ts",
    "test:invoice": "wdio run ./config/wdio.siebel.conf.ts --spec ./specs/siebel_invoice_validation.spec.ts",
    "test:complete-flow": "wdio run ./config/wdio.siebel.conf.ts --spec ./specs/siebel_complete_flow.spec.ts",
    "test:invoice-extraction": "wdio run ./config/wdio.siebel.conf.ts --spec ./specs/invoice-extraction.spec.ts",
    "test:debug": "wdio run ./config/wdio.siebel.conf.ts --spec ./specs/debug-test.spec.ts"
  },
  "dependencies": {
    "chai": "^4.5.0",
    "exceljs": "^3.4.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "webdriverio": "^9.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/pdf-parse": "^1.1.5",
    "@wdio/allure-reporter": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/junit-reporter": "^9.21.0",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "chai": "^4.3.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "mocha": "^11.7.6",
    "pdf-parse": "^2.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "wdio-json-html-reporter": "^1.5.14"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
